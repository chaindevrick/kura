{
  "name": "kura-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "cert:gen": "bash ./scripts/generate-local-cert.sh",
    "build": "next build",
    "build:prod": "NODE_ENV=production next build",
    "build:static": "BUILD_MODE=export next build && du -sh out",
    "build:standalone": "BUILD_MODE=standalone next build && du -sh .next/standalone",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "deploy": "bash ./scripts/deploy.sh",
    "deploy:cloud-run": "npm run build:standalone && gcloud run deploy kura-web --source . --project kura-b39eb --region us-central1 --allow-unauthenticated",
    "lint": "eslint"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19",
    "@tanstack/react-query": "^5.100.5",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "hash-wasm": "^4.12.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-plaid-link": "^4.1.1",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tssrp6a": "^3.0.0",
    "viem": "^2.48.4",
    "wagmi": "^3.6.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

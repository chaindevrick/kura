# ============================================================================
# Kura App - 环境变量配置
# ============================================================================
# 复制此文件为 .env.local (开发) 或 .env.production (生产)
# 然后填入实际的密钥和 URL

# ============================================================================
# Web3 / WalletConnect
# ============================================================================
# WalletConnect Project ID
# 获取: https://cloud.walletconnect.com
# 用途: Web3 钱包连接（目前禁用，placeholder）
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ============================================================================
# Backend API
# ============================================================================
# 后端 API 地址（生产环境用 HTTPS）
EXPO_PUBLIC_BACKEND_URL=https://your-backend-url.com

# 本地开发专用 HTTP 地址（仅在 NODE_ENV=development 时使用）
# 注意：生产环境不应设置此项
# EXPO_PUBLIC_BACKEND_URL_DEV=http://localhost:8080

# ============================================================================
# Environment
# ============================================================================
# APP_ENV: development | production
APP_ENV=development
# NODE_ENV: development | production
NODE_ENV=development

# ============================================================================
# RevenueCat
# ============================================================================
EXPO_PUBLIC_REVENUECAT_API_KEY=your_revenuecat_api_key